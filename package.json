{
  "name": "lifeline-app",
  "version": "1.0.0",
  "description": "LifeLine emergency app — Android + iOS wrapper (Capacitor)",
  "private": true,
  "scripts": {
    "sync": "cap sync",
    "sync:android": "cap sync android",
    "sync:ios": "cap sync ios",
    "open:android": "cap open android",
    "open:ios": "cap open ios",
    "build:apk": "cap sync android && cd android && ./gradlew assembleDebug",
    "build:aab": "cap sync android && cd android && ./gradlew bundleRelease"
  },
  "keywords": [
    "lifeline",
    "emergency",
    "capacitor",
    "android",
    "ios"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2"
  }
}
